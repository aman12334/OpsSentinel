{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opssentinel.dev/schemas/event.schema.json",
  "title": "OpsSentinel Event",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "source",
    "timestamp",
    "entity",
    "related_entities",
    "severity",
    "text",
    "signals",
    "context",
    "confidence",
    "schema_version"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "entity": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["truck", "shipment", "order"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "related_entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "id"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["truck", "shipment", "order"]
          },
          "id": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "text": {
      "type": "string",
      "minLength": 1
    },
    "signals": {
      "type": "object",
      "additionalProperties": true
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "schema_version": {
      "type": "string",
      "const": "1.0"
    }
  },
  "additionalProperties": false
}
